// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/dotnet
{
	"name": "storypop-eventplatform",
	"service": "storypop-eventplatform",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	//"image": "mcr.microsoft.com/devcontainers/dotnet:2-9.0",
	"dockerComposeFile": "../../docker-storypop/docker-compose.yml",
	// 2. Specify the path inside the container where the code is mounted
	"workspaceFolder": "/workspaces/storypop-eventplatform",
	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
 		// 1.  installs curl/wget for the other features
		"ghcr.io/devcontainers/features/common-utils:1": {
			"installZsh": true,
			"upgradePackages": false
		}
/* 		// 2. Then .NET 
		"ghcr.io/devcontainers/features/dotnet:2": {
			"version": "9.0"
		}  */
	},
	"customizations": {
		"vscode": {
			"settings": {
				"git.enabled": false,
				"git.autofetch": false,
				 "extensions.verifySignature": false
			}
		}
	},
	"mounts": [
		"source=vscode-server-bin,target=/root/.vscode-server/bin,type=volume"
	],
	// ADD THESE TWO LINES:
	"overrideCommand": true,
	"containerEnv": {
		"VSCODE_AGENT_FOLDER": "/root/.vscode-server"
	}
}